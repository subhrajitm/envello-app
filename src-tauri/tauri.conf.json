{
  "productName": "Envello",
  "version": "0.1.3",
  "identifier": "com.envello.app",
  "build": {
    "beforeDevCommand": "CI=true npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:4200",
    "frontendDist": "../dist/apps/desktop/browser"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": false,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "fullscreen": false,
        "resizable": true,
        "title": "Envello",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "transparent": true,
        "titleBarStyle": "Overlay"
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "entitlements": "./entitlements.plist",
      "infoPlist": "./Info.plist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY3NUI0NDlEMzRDNEEwQTMKUldTam9NUTBuVVJiOTFONGdMMTE2T1VLQmlzekJYQ0VRYWR1c2NhRTNxR1RDdkRFUDFLV0hBdlQK",
      "endpoints": [
        "https://github.com/subhrajitm/envello-app/releases/latest/download/latest.json"
      ]
    },
    "deep-link": {
      "mobile": [],
      "desktop": {
        "schemes": ["envello"]
      }
    }
  }
}