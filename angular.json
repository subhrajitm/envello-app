{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "desktop": {
      "projectType": "application",
      "schematics": {},
      "root": "apps/desktop",
      "sourceRoot": "apps/desktop/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/apps/desktop",
            "index": "apps/desktop/src/index.html",
            "browser": "apps/desktop/src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "apps/desktop/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "apps/desktop/public"
              },
              {
                "glob": "**/*",
                "input": "apps/desktop/src/assets",
                "output": "assets"
              }
            ],
            "styles": [
              "apps/desktop/src/styles.css"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "1.5MB",
                  "maximumError": "2.5MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "60kB",
                  "maximumError": "80kB"
                }
              ],
              "outputHashing": "all",
              "fileReplacements": [
                {
                  "replace": "apps/desktop/src/environments/environment.ts",
                  "with": "apps/desktop/src/environments/environment.prod.ts"
                }
              ]
            },
            "staging": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "1.5MB",
                  "maximumError": "2.5MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "20kB",
                  "maximumError": "40kB"
                }
              ],
              "outputHashing": "all",
              "fileReplacements": [
                {
                  "replace": "apps/desktop/src/environments/environment.ts",
                  "with": "apps/desktop/src/environments/environment.staging.ts"
                }
              ]
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "desktop:build:production"
            },
            "development": {
              "buildTarget": "desktop:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ],
            "tsConfig": "apps/desktop/tsconfig.spec.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "apps/desktop/public"
              }
            ],
            "styles": [
              "apps/desktop/src/styles.css"
            ],
            "scripts": []
          }
        }
      }
    },
    "web": {
      "projectType": "application",
      "schematics": {},
      "root": "apps/web",
      "sourceRoot": "apps/web/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/apps/web",
            "index": "apps/web/src/index.html",
            "browser": "apps/web/src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "apps/web/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "apps/web/public"
              }
            ],
            "styles": [
              "apps/web/src/styles.css"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "1.5MB",
                  "maximumError": "2.5MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "60kB",
                  "maximumError": "80kB"
                }
              ],
              "outputHashing": "all",
              "fileReplacements": [
                {
                  "replace": "apps/web/src/environments/environment.ts",
                  "with": "apps/web/src/environments/environment.prod.ts"
                }
              ]
            },
            "staging": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "1.5MB",
                  "maximumError": "2.5MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "20kB",
                  "maximumError": "40kB"
                }
              ],
              "outputHashing": "all",
              "fileReplacements": [
                {
                  "replace": "apps/web/src/environments/environment.ts",
                  "with": "apps/web/src/environments/environment.staging.ts"
                }
              ]
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "web:build:production"
            },
            "development": {
              "buildTarget": "web:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ],
            "tsConfig": "apps/web/tsconfig.spec.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "apps/web/public"
              }
            ],
            "styles": [
              "apps/web/src/styles.css"
            ],
            "scripts": []
          }
        }
      }
    },
    "shared-core": {
      "projectType": "library",
      "root": "projects/shared/core",
      "sourceRoot": "projects/shared/core/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "projects/shared/core/ng-package.json"
          }
        }
      }
    },
    "shared-state": {
      "projectType": "library",
      "root": "projects/shared/state",
      "sourceRoot": "projects/shared/state/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "projects/shared/state/ng-package.json"
          }
        }
      }
    },
    "shared-domain": {
      "projectType": "library",
      "root": "projects/shared/domain",
      "sourceRoot": "projects/shared/domain/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "projects/shared/domain/ng-package.json"
          }
        }
      }
    },
    "shared-data": {
      "projectType": "library",
      "root": "projects/shared/data",
      "sourceRoot": "projects/shared/data/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "projects/shared/data/ng-package.json"
          }
        }
      }
    }
  }
}