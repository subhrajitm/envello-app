/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options. */
{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/app",
    "types": [],
    "baseUrl": "../../",
    "paths": {
      "@envello/shared-core": [
        "dist/shared/core"
      ],
      "@envello/shared-state": [
        "dist/shared/state"
      ],
      "@envello/shared-domain": [
        "dist/shared/domain"
