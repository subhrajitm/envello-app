{
  "productName": "Envello",
  "version": "0.1.0",
  "identifier": "com.envello.mobile",
  "build": {
    "beforeDevCommand": "npm exec nx serve mobile -- --port 4202 --host 0.0.0.0",
    "beforeBuildCommand": "npm exec nx build mobile",
    "devUrl": "http://localhost:4202",
    "frontendDist": "../../dist/apps/mobile"
  },
  "app": {
    "withGlobalTauri": false,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "iOS": {
      "minimumSystemVersion": "16.0"
    },
    "android": {
      "minSdkVersion": 24
    }
  }
}
